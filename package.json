{
  "name": "vite-react-tanstack-router-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.2",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:types": "curl -s http://localhost:3050/api/openapi/json | bun x openapi-typescript --output src/api/generated.d.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/router-plugin": "^1.95.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "latest",
    "jsdom": "^28.1.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "trustedDependencies": [
    "esbuild",
    "lightningcss",
    "sharp"
  ]
}
